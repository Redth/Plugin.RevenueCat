{
  "current_offering_id": "packages",
  "offerings": [
    {
      "identifier": "packages",
      "description": "Package selector example",
      "packages": [
        { "identifier": "$rc_monthly", "platform_product_identifier": "pro_monthly" },
        { "identifier": "$rc_annual", "platform_product_identifier": "pro_annual" },
        { "identifier": "$rc_lifetime", "platform_product_identifier": "pro_lifetime" }
      ],
      "paywall_components": {
        "id": "packages_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "hex", "value": "#ffffffff" } } },
            "stack": {
              "type": "stack",
              "spacing": 14,
              "padding": { "top": 38, "bottom": 24, "leading": 18, "trailing": 18 },
              "components": [
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#111827ff" } } },
                { "type": "text", "id": "subtitle", "text_lid": "subtitle", "font_size": "body_m", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#4b5563ff" } } },
                {
                  "type": "package",
                  "id": "monthly",
                  "package_id": "$rc_monthly",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "spacing": 3,
                    "padding": { "top": 16, "bottom": 16, "leading": 16, "trailing": 16 },
                    "background_color": { "light": { "type": "hex", "value": "#f1f5f9ff" } },
                    "components": [
                      { "type": "text", "id": "monthly-title", "text_lid": "monthly_title", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#111827ff" } } },
                      { "type": "text", "id": "monthly-price", "text_lid": "monthly_price", "font_size": "body_m", "color": { "light": { "type": "hex", "value": "#4b5563ff" } } }
                    ]
                  }
                },
                {
                  "type": "package",
                  "id": "annual",
                  "package_id": "$rc_annual",
                  "stack": {
                    "type": "stack",
                    "spacing": 3,
                    "padding": { "top": 16, "bottom": 16, "leading": 16, "trailing": 16 },
                    "background_color": { "light": { "type": "hex", "value": "#ecfdf5ff" } },
                    "components": [
                      { "type": "text", "id": "annual-title", "text_lid": "annual_title", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#065f46ff" } } },
                      { "type": "text", "id": "annual-price", "text_lid": "annual_price", "font_size": "body_m", "color": { "light": { "type": "hex", "value": "#047857ff" } } }
                    ]
                  }
                },
                {
                  "type": "package",
                  "id": "lifetime",
                  "package_id": "$rc_lifetime",
                  "stack": {
                    "type": "stack",
                    "spacing": 3,
                    "padding": { "top": 16, "bottom": 16, "leading": 16, "trailing": 16 },
                    "background_color": { "light": { "type": "hex", "value": "#fff7edff" } },
                    "components": [
                      { "type": "text", "id": "life-title", "text_lid": "life_title", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#9a3412ff" } } },
                      { "type": "text", "id": "life-price", "text_lid": "life_price", "font_size": "body_m", "color": { "light": { "type": "hex", "value": "#c2410cff" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 16, "bottom": 24, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "background_color": { "light": { "type": "hex", "value": "#16a34aff" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "title": "Choose a plan",
            "subtitle": "Tap each card to validate selection state and purchase event payloads.",
            "monthly_title": "Monthly - {{ price }}",
            "monthly_price": "Flexible billing every {{ sub_period }}.",
            "annual_title": "Annual - best value",
            "annual_price": "{{ price }} per {{ sub_period }}.",
            "life_title": "Lifetime",
            "life_price": "{{ price }} one time.",
            "cta": "Continue"
          }
        },
        "default_locale": "en_US"
      }
    }
  ],
  "ui_config": { "app": { "colors": {}, "fonts": {} }, "localizations": {}, "variable_config": {}, "custom_variables": {} }
}
