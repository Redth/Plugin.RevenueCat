{
  "current_offering_id": "carousel",
  "offerings": [
    {
      "identifier": "carousel",
      "description": "Carousel onboarding example",
      "packages": [
        { "identifier": "$rc_monthly", "platform_product_identifier": "pro_monthly" }
      ],
      "paywall_components": {
        "id": "carousel_onboarding_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "hex", "value": "#f8fafcff" } } },
            "stack": {
              "type": "stack",
              "spacing": 18,
              "padding": { "top": 30, "bottom": 20, "leading": 18, "trailing": 18 },
              "components": [
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#0f172aff" } } },
                {
                  "type": "carousel",
                  "id": "value-carousel",
                  "page_alignment": "center",
                  "page_spacing": 12,
                  "page_peek": 18,
                  "initial_page_index": 0,
                  "loop": true,
                  "auto_advance": { "ms_time_per_page": 2500, "ms_transition_time": 300, "transition_type": "slide" },
                  "size": { "height": { "type": "fixed", "value": 250 } },
                  "page_control": {
                    "position": "bottom",
                    "spacing": 8,
                    "default": { "width": 8, "height": 8, "color": { "light": { "type": "hex", "value": "#cbd5e1ff" } } },
                    "active": { "width": 20, "height": 8, "color": { "light": { "type": "hex", "value": "#2563ebff" } } }
                  },
                  "pages": [
                    {
                      "type": "stack",
                      "spacing": 12,
                      "padding": { "top": 24, "bottom": 24, "leading": 20, "trailing": 20 },
                      "shape": { "type": "rectangle", "corners": { "all": 28 } },
                      "background_color": { "light": { "type": "linear", "degrees": 135, "points": [ { "color": "#dbeafeff", "percent": 0 }, { "color": "#eff6ffff", "percent": 100 } ] } },
                      "components": [
                        { "type": "icon", "id": "slide-one-icon", "formats": { "svg": "paywall_star.svg" }, "size": { "width": { "type": "fixed", "value": 58 }, "height": { "type": "fixed", "value": 58 } } },
                        { "type": "text", "id": "slide-one-title", "text_lid": "slide_1_title", "font_size": "heading_s", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#1e3a8aff" } } },
                        { "type": "text", "id": "slide-one-copy", "text_lid": "slide_1_copy", "font_size": "body_m", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#334155ff" } } }
                      ]
                    },
                    {
                      "type": "stack",
                      "spacing": 12,
                      "padding": { "top": 24, "bottom": 24, "leading": 20, "trailing": 20 },
                      "shape": { "type": "rectangle", "corners": { "all": 28 } },
                      "background_color": { "light": { "type": "linear", "degrees": 135, "points": [ { "color": "#dcfce7ff", "percent": 0 }, { "color": "#f0fdf4ff", "percent": 100 } ] } },
                      "components": [
                        { "type": "icon", "id": "slide-two-icon", "formats": { "svg": "paywall_check.svg" }, "size": { "width": { "type": "fixed", "value": 58 }, "height": { "type": "fixed", "value": 58 } } },
                        { "type": "text", "id": "slide-two-title", "text_lid": "slide_2_title", "font_size": "heading_s", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#14532dff" } } },
                        { "type": "text", "id": "slide-two-copy", "text_lid": "slide_2_copy", "font_size": "body_m", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#166534ff" } } }
                      ]
                    }
                  ]
                },
                {
                  "type": "package",
                  "id": "monthly",
                  "package_id": "$rc_monthly",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "padding": { "top": 16, "bottom": 16, "leading": 18, "trailing": 18 },
                    "shape": { "type": "pill" },
                    "background_color": { "light": { "type": "hex", "value": "#ffffffff" } },
                    "components": [
                      { "type": "text", "id": "package", "text_lid": "package", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#2563ebff" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 14, "bottom": 22, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "shape": { "type": "pill" },
                      "background_color": { "light": { "type": "hex", "value": "#2563ebff" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "title": "Swipe through what Pro unlocks",
            "slide_1_title": "Personalized insights",
            "slide_1_copy": "Carousel pages mirror the RevenueCat page model with spacing, peek, and indicators.",
            "slide_2_title": "Workflow automation",
            "slide_2_copy": "Each page is still a normal stack, so existing text, icon, and shape rendering applies.",
            "package": "{{ product_name }} - {{ price }}",
            "cta": "Continue"
          }
        },
        "default_locale": "en_US"
      }
    }
  ],
  "ui_config": { "app": { "colors": {}, "fonts": {} }, "localizations": {}, "variable_config": {}, "custom_variables": {} }
}
