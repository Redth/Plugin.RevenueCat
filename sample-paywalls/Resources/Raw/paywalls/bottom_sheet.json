                      }
                    },
                    {
                      "type": "button",
                      "id": "restore",
                      "action": { "type": "restore_purchases" },
                      "stack": {
                        "type": "stack",
                        "padding": { "top": 10, "bottom": 10, "leading": 12, "trailing": 12 },
                        "components": [
                          { "type": "text", "id": "restore-text", "text_lid": "restore", "font_size": "body_s", "color": { "light": { "type": "hex", "value": "#64748bff" } } }
