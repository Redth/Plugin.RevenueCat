{
  "current_offering_id": "lifetime",
  "offerings": [
    {
      "identifier": "lifetime",
      "description": "Lifetime offer example",
      "packages": [
        { "identifier": "$rc_lifetime", "platform_product_identifier": "pro_lifetime" }
      ],
      "paywall_components": {
        "id": "lifetime_offer_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "hex", "value": "#fff7edff" } } },
            "header": {
              "type": "header",
              "stack": {
                "type": "stack",
                "padding": { "top": 18, "bottom": 8, "leading": 18, "trailing": 18 },
                "components": [
                  { "type": "image", "id": "wave", "source": "paywall_wave.svg", "fit_mode": "fill", "mask_shape": { "type": "rectangle", "corners": { "topLeading": 34, "topTrailing": 34, "bottomLeading": 34, "bottomTrailing": 34 } }, "shadow": { "color": { "light": { "type": "hex", "value": "#7c2d12ff" } }, "radius": 18, "x": 0, "y": 8 }, "size": { "height": { "type": "fixed", "value": 190 } } }
                ]
              }
            },
            "stack": {
              "type": "stack",
              "spacing": 15,
              "padding": { "top": 16, "bottom": 20, "leading": 24, "trailing": 24 },
              "components": [
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#7c2d12ff" } } },
                { "type": "text", "id": "subtitle", "text_lid": "subtitle", "font_size": "body_l", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#9a3412ff" } } },
                {
                  "type": "package",
                  "id": "lifetime-package",
                  "package_id": "$rc_lifetime",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "padding": { "top": 20, "bottom": 20, "leading": 20, "trailing": 20 },
                    "shape": { "type": "rectangle", "corners": { "topLeading": 28, "topTrailing": 28, "bottomLeading": 28, "bottomTrailing": 28 } },
                    "background_color": { "light": { "type": "hex", "value": "#ffffffff" } },
                    "border": { "color": { "light": { "type": "hex", "value": "#fb923cff" } }, "width": 2 },
                    "components": [
                      { "type": "text", "id": "package-title", "text_lid": "package_title", "font_size": "body_xl", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#7c2d12ff" } } },
                      { "type": "text", "id": "package-price", "text_lid": "package_price", "font_size": "heading_s", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ea580cff" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 16, "bottom": 24, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "shape": { "type": "pill" },
                      "background_color": { "light": { "type": "hex", "value": "#ea580cff" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "title": "Launch lifetime access",
            "subtitle": "A one-time purchase template with a warm hero and prominent lifetime card.",
            "package_title": "{{ product_name }}",
            "package_price": "{{ price }} one time",
            "cta": "Get lifetime access"
          }
        },
        "default_locale": "en_US"
      }
    }
