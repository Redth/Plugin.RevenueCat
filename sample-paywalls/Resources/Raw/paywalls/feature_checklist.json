{
  "current_offering_id": "checklist",
  "offerings": [
    {
      "identifier": "checklist",
      "description": "Checklist paywall example",
      "packages": [
        { "identifier": "$rc_monthly", "platform_product_identifier": "pro_monthly" }
      ],
      "paywall_components": {
        "id": "feature_checklist_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "hex", "value": "#ffffffff" } } },
            "stack": {
              "type": "stack",
              "spacing": 16,
              "padding": { "top": 34, "bottom": 24, "leading": 22, "trailing": 22 },
              "components": [
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#111827ff" } } },
                { "type": "text", "id": "subtitle", "text_lid": "subtitle", "font_size": "body_m", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#4b5563ff" } } },
                {
                  "type": "stack",
                  "id": "feature-one",
                  "dimension": { "type": "horizontal", "alignment": "center", "distribution": "start" },
                  "spacing": 12,
                  "padding": { "top": 12, "bottom": 12, "leading": 14, "trailing": 14 },
                  "shape": { "type": "rectangle", "corners": { "topLeading": 18, "topTrailing": 18, "bottomLeading": 18, "bottomTrailing": 18 } },
                  "background_color": { "light": { "type": "hex", "value": "#f0fdf4ff" } },
                  "components": [
                    { "type": "icon", "id": "check-one", "formats": { "svg": "paywall_check.svg" }, "size": { "width": { "type": "fixed", "value": 34 }, "height": { "type": "fixed", "value": 34 } } },
                    { "type": "text", "id": "feature-one-text", "text_lid": "feature_1", "font_size": "body_m", "horizontal_alignment": "leading", "color": { "light": { "type": "hex", "value": "#14532dff" } } }
                  ]
                },
                {
                  "type": "stack",
                  "id": "feature-two",
                  "dimension": { "type": "horizontal", "alignment": "center", "distribution": "start" },
                  "spacing": 12,
                  "padding": { "top": 12, "bottom": 12, "leading": 14, "trailing": 14 },
                  "shape": { "type": "rectangle", "corners": { "topLeading": 18, "topTrailing": 18, "bottomLeading": 18, "bottomTrailing": 18 } },
                  "background_color": { "light": { "type": "hex", "value": "#eff6ffff" } },
                  "components": [
                    { "type": "icon", "id": "check-two", "formats": { "svg": "paywall_check.svg" }, "size": { "width": { "type": "fixed", "value": 34 }, "height": { "type": "fixed", "value": 34 } } },
                    { "type": "text", "id": "feature-two-text", "text_lid": "feature_2", "font_size": "body_m", "horizontal_alignment": "leading", "color": { "light": { "type": "hex", "value": "#1e3a8aff" } } }
                  ]
                },
                {
                  "type": "package",
                  "id": "monthly",
                  "package_id": "$rc_monthly",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "padding": { "top": 18, "bottom": 18, "leading": 18, "trailing": 18 },
                    "shape": { "type": "rectangle", "corners": { "topLeading": 24, "topTrailing": 24, "bottomLeading": 24, "bottomTrailing": 24 } },
                    "border": { "color": { "light": { "type": "hex", "value": "#2563ebff" } }, "width": 1.5 },
                    "background_color": { "light": { "type": "hex", "value": "#ffffffff" } },
                    "components": [
                      { "type": "text", "id": "package", "text_lid": "package", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#111827ff" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 16, "bottom": 24, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "shape": { "type": "pill" },
                      "background_color": { "light": { "type": "hex", "value": "#2563ebff" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "title": "Everything in Pro",
            "subtitle": "Checklist-style templates are common in RevenueCatUI paywalls.",
            "feature_1": "Smart recommendations and advanced filters",
            "feature_2": "Cloud sync, backups, and priority support",
            "package": "{{ product_name }} for {{ price }} / {{ sub_period }}",
            "cta": "Upgrade now"
          }
        },
        "default_locale": "en_US"
      }
    }
  ],
  "ui_config": { "app": { "colors": {}, "fonts": {} }, "localizations": {}, "variable_config": {}, "custom_variables": {} }
}
