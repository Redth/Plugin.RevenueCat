{
  "current_offering_id": "benefits",
  "offerings": [
    {
      "identifier": "benefits",
      "description": "Two-column benefits example",
      "packages": [
        { "identifier": "$rc_six_month", "platform_product_identifier": "pro_six_month" }
      ],
      "paywall_components": {
        "id": "two_column_benefits_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "alias", "value": "page" } } },
            "stack": {
              "type": "stack",
              "spacing": 16,
              "padding": { "top": 34, "bottom": 24, "leading": 18, "trailing": 18 },
              "components": [
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_l", "font_weight": "bold", "color": { "light": { "type": "alias", "value": "ink" } } },
                {
                  "type": "stack",
                  "id": "row-one",
                  "dimension": { "type": "horizontal", "alignment": "center", "distribution": "center" },
                  "spacing": 10,
                  "components": [
                    {
                      "type": "stack",
                      "id": "card-one",
                      "spacing": 8,
                      "padding": { "top": 16, "bottom": 16, "leading": 12, "trailing": 12 },
                      "shape": { "type": "rectangle", "corners": { "topLeading": 20, "topTrailing": 20, "bottomLeading": 20, "bottomTrailing": 20 } },
                      "background_color": { "light": { "type": "alias", "value": "card_a" } },
                      "components": [
                        { "type": "icon", "id": "card-one-icon", "formats": { "svg": "paywall_star.svg" }, "size": { "width": { "type": "fixed", "value": 42 }, "height": { "type": "fixed", "value": 42 } } },
                        { "type": "text", "id": "card-one-text", "text_lid": "card_1", "font_size": "body_s", "font_weight": "bold", "color": { "light": { "type": "alias", "value": "ink" } } }
                      ]
                    },
                    {
                      "type": "stack",
                      "id": "card-two",
                      "spacing": 8,
                      "padding": { "top": 16, "bottom": 16, "leading": 12, "trailing": 12 },
                      "shape": { "type": "rectangle", "corners": { "topLeading": 20, "topTrailing": 20, "bottomLeading": 20, "bottomTrailing": 20 } },
                      "background_color": { "light": { "type": "alias", "value": "card_b" } },
                      "components": [
                        { "type": "icon", "id": "card-two-icon", "formats": { "svg": "paywall_check.svg" }, "size": { "width": { "type": "fixed", "value": 42 }, "height": { "type": "fixed", "value": 42 } } },
                        { "type": "text", "id": "card-two-text", "text_lid": "card_2", "font_size": "body_s", "font_weight": "bold", "color": { "light": { "type": "alias", "value": "ink" } } }
                      ]
                    }
                  ]
                },
                {
                  "type": "package",
                  "id": "six-month",
                  "package_id": "$rc_six_month",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "padding": { "top": 18, "bottom": 18, "leading": 18, "trailing": 18 },
                    "shape": { "type": "rectangle", "corners": { "topLeading": 26, "topTrailing": 26, "bottomLeading": 26, "bottomTrailing": 26 } },
                    "background_color": { "light": { "type": "alias", "value": "card_selected" } },
                    "components": [
                      { "type": "text", "id": "package", "text_lid": "package", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "alias", "value": "accent" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 16, "bottom": 24, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "shape": { "type": "pill" },
                      "background_color": { "light": { "type": "alias", "value": "accent" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "title": "A grid of benefits",
            "card_1": "Exclusive insights",
            "card_2": "Done-for-you setup",
            "package": "{{ product_name }} - {{ price }}",
            "cta": "Claim half-year access"
          }
        },
        "default_locale": "en_US"
      }
    }
  ],
  "ui_config": {
    "app": {
      "colors": {
        "page": { "light": { "type": "hex", "value": "#f5f3ffff" } },
        "ink": { "light": { "type": "hex", "value": "#2e1065ff" } },
        "accent": { "light": { "type": "hex", "value": "#7c3aedff" } },
        "card_a": { "light": { "type": "hex", "value": "#ede9feff" } },
        "card_b": { "light": { "type": "hex", "value": "#dcfce7ff" } },
        "card_selected": { "light": { "type": "hex", "value": "#ffffffff" } }
      },
      "fonts": {}
    },
    "localizations": {},
    "variable_config": {},
    "custom_variables": {}
  }
}
