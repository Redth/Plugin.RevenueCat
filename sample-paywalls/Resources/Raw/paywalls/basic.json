{
  "current_offering_id": "basic",
  "offerings": [
    {
      "identifier": "basic",
      "description": "Basic paywall example",
      "packages": [
        { "identifier": "$rc_monthly", "platform_product_identifier": "pro_monthly" }
      ],
      "paywall_components": {
        "id": "basic_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "hex", "value": "#ffffffff" } } },
            "stack": {
              "type": "stack",
              "id": "basic-root",
              "spacing": 18,
              "padding": { "top": 44, "bottom": 28, "leading": 24, "trailing": 24 },
              "components": [
                { "type": "text", "id": "eyebrow", "text_lid": "eyebrow", "font_size": "body_s", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#2563ebff" } } },
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_xl", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#111827ff" } } },
                { "type": "text", "id": "subtitle", "text_lid": "subtitle", "font_size": "body_l", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#4b5563ff" } } },
                {
                  "type": "package",
                  "id": "monthly-card",
                  "package_id": "$rc_monthly",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "spacing": 4,
                    "padding": { "top": 18, "bottom": 18, "leading": 18, "trailing": 18 },
                    "shape": { "type": "rectangle", "corners": { "all": 20 } },
                    "background_color": { "light": { "type": "hex", "value": "#eff6ffff" } },
                    "components": [
                      { "type": "text", "id": "package-title", "text_lid": "package_title", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#111827ff" } } },
                      { "type": "text", "id": "package-price", "text_lid": "package_price", "font_size": "body_m", "color": { "light": { "type": "hex", "value": "#4b5563ff" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "id": "basic-footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 16, "bottom": 24, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "shape": { "type": "pill" },
                      "background_color": { "light": { "type": "hex", "value": "#2563ebff" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "eyebrow": "OFFLINE FIXTURE",
            "title": "Go Pro",
            "subtitle": "Render a RevenueCat paywall using only MAUI controls.",
            "package_title": "{{ product_name }}",
            "package_price": "{{ price }} / {{ sub_period }}",
            "cta": "Subscribe with {{ price }}"
          }
        },
        "default_locale": "en_US"
      }
    }
  ],
  "ui_config": { "app": { "colors": {}, "fonts": {} }, "localizations": {}, "variable_config": {}, "custom_variables": {} }
}
