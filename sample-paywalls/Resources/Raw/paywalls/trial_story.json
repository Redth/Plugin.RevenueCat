{
  "current_offering_id": "trial_story",
  "offerings": [
    {
      "identifier": "trial_story",
      "description": "Trial story example",
      "packages": [
        { "identifier": "$rc_three_month", "platform_product_identifier": "pro_three_month" }
      ],
      "paywall_components": {
        "id": "trial_story_fixture",
        "template_name": "components",
        "revision": 1,
        "components_config": {
          "base": {
            "background": { "type": "color", "value": { "light": { "type": "hex", "value": "#ecfeffff" } } },
            "stack": {
              "type": "stack",
              "spacing": 14,
              "padding": { "top": 34, "bottom": 24, "leading": 20, "trailing": 20 },
              "components": [
                { "type": "text", "id": "title", "text_lid": "title", "font_size": "heading_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#164e63ff" } } },
                { "type": "text", "id": "subtitle", "text_lid": "subtitle", "font_size": "body_m", "horizontal_alignment": "center", "color": { "light": { "type": "hex", "value": "#155e75ff" } } },
                {
                  "type": "timeline",
                  "id": "future-timeline",
                  "fallback": {
                    "type": "stack",
                    "id": "timeline-fallback",
                    "spacing": 10,
                    "components": [
                      {
                        "type": "stack",
                        "id": "story-one",
                        "padding": { "top": 14, "bottom": 14, "leading": 16, "trailing": 16 },
                        "shape": { "type": "rectangle", "corners": { "topLeading": 20, "topTrailing": 20, "bottomLeading": 20, "bottomTrailing": 20 } },
                        "background_color": { "light": { "type": "hex", "value": "#ffffffff" } },
                        "components": [
                          { "type": "text", "id": "story-one-text", "text_lid": "story_1", "font_size": "body_m", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#164e63ff" } } }
                        ]
                      },
                      {
                        "type": "stack",
                        "id": "story-two",
                        "padding": { "top": 14, "bottom": 14, "leading": 16, "trailing": 16 },
                        "shape": { "type": "rectangle", "corners": { "topLeading": 20, "topTrailing": 20, "bottomLeading": 20, "bottomTrailing": 20 } },
                        "background_color": { "light": { "type": "hex", "value": "#cffafeff" } },
                        "components": [
                          { "type": "text", "id": "story-two-text", "text_lid": "story_2", "font_size": "body_m", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#155e75ff" } } }
                        ]
                      }
                    ]
                  }
                },
                {
                  "type": "package",
                  "id": "season-pass",
                  "package_id": "$rc_three_month",
                  "is_selected_by_default": true,
                  "stack": {
                    "type": "stack",
                    "padding": { "top": 18, "bottom": 18, "leading": 18, "trailing": 18 },
                    "shape": { "type": "rectangle", "corners": { "topLeading": 24, "topTrailing": 24, "bottomLeading": 24, "bottomTrailing": 24 } },
                    "background_color": { "light": { "type": "hex", "value": "#ffffffff" } },
                    "border": { "color": { "light": { "type": "hex", "value": "#06b6d4ff" } }, "width": 2 },
                    "components": [
                      { "type": "text", "id": "package", "text_lid": "package", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#164e63ff" } } }
                    ]
                  }
                }
              ]
            },
            "sticky_footer": {
              "type": "footer",
              "stack": {
                "type": "stack",
                "padding": { "top": 16, "bottom": 24, "leading": 24, "trailing": 24 },
                "components": [
                  {
                    "type": "purchase_button",
                    "id": "purchase",
                    "stack": {
                      "type": "stack",
                      "padding": { "top": 15, "bottom": 15, "leading": 20, "trailing": 20 },
                      "shape": { "type": "pill" },
                      "background_color": { "light": { "type": "hex", "value": "#0891b2ff" } },
                      "components": [
                        { "type": "text", "id": "cta", "text_lid": "cta", "font_size": "body_l", "font_weight": "bold", "color": { "light": { "type": "hex", "value": "#ffffffff" } } }
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "components_localizations": {
          "en_US": {
            "title": "Your first week in Pro",
            "subtitle": "This fixture keeps a timeline-shaped fallback for components not yet implemented.",
            "story_1": "Day 1: unlock the complete library",
            "story_2": "Day 3: get personalized recommendations",
            "package": "{{ product_name }} - {{ price }}",
            "cta": "Start the journey"
          }
        },
        "default_locale": "en_US"
      }
    }
  ],
  "ui_config": { "app": { "colors": {}, "fonts": {} }, "localizations": {}, "variable_config": {}, "custom_variables": {} }
}
